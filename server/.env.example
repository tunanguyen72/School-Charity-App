# ==== Cấu hình máy chủ "Cùng em đến trường" ====
# Sao chép file này thành .env rồi điền giá trị thật khi cần.

# Cổng API (mặc định 4000)
PORT=4000

# Khoá ký JWT — BẮT BUỘC đặt giá trị ngẫu nhiên, dài ở môi trường production.
# Dev có thể bỏ trống (dùng giá trị mặc định trong code).
JWT_SECRET=

# Giới hạn nguồn gọi API (CORS). Bỏ trống = cho phép mọi nguồn (chỉ nên dùng khi dev).
# Nhiều origin ngăn cách bằng dấu phẩy, ví dụ: https://app.example.com,https://admin.example.com
CORS_ORIGIN=
